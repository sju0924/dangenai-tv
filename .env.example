# ─── GCP ───────────────────────────────────────────────
GCP_PROJECT_ID=project-9ed97ef0-254a-4ec3-975

# Gemini/Vertex AI 리전 (gemini-2.5-flash-lite → us-central1 필수)
VERTEX_LOCATION=us-central1
FIRESTORE_DATABASE=dangenai-skills

# Dialogflow CX Agent ID (GCP 콘솔 > Agent Builder > 에이전트 선택 > 설정에서 확인)
DIALOGFLOW_AGENT_ID=YOUR_AGENT_ID

# Cloud Functions 배포 후 URL 입력
# 예: https://asia-northeast3-project-xxxx.cloudfunctions.net/handle-skill
WEBHOOK_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/handle-skill

# ─── skill-engine Cloud Run 배포 URL ───────────────────
SKILL_ENGINE_URL=https://skill-engine-xxxx-an.a.run.app

# ─── 서비스 계정 키 (로컬 테스트용만) ─────────────────
# Cloud Run / Cloud Functions 환경에서는 불필요 (Workload Identity 사용)
GOOGLE_APPLICATION_CREDENTIALS=../sa-key.json
